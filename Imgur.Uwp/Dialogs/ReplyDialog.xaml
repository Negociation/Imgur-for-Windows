<ContentDialog
    x:Class="Imgur.Uwp.Dialogs.ReplyDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Imgur.Uwp.Dialogs"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    RequestedTheme="Dark"
    Background="#34343A"
    Opacity="1"
    xmlns:Windows10version1809="http://schemas.microsoft.com/winfx/2006/xaml/presentation?IsApiContractPresent(Windows.Foundation.UniversalApiContract, 7)"
    xmlns:Windows10FallCreatorsUpdate="http://schemas.microsoft.com/winfx/2006/xaml/presentation?IsApiContractPresent(Windows.Foundation.UniversalApiContract, 5)"
    xmlns:controls="using:Imgur.Uwp.Controls"
    xmlns:toolkit="using:Microsoft.Toolkit.Uwp.UI.Controls"
    Windows10version1809:CornerRadius="5"
    FullSizeDesired="False"
    VerticalAlignment="Center">
    <ContentDialog.Resources>
        <Thickness x:Key="ContentDialogPadding">0,10,0,10</Thickness>
    </ContentDialog.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>
        <!-- Header -->
        <Grid Grid.Row="0" Padding="10,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Foreground="#2fbe7c"
                       FontSize="20" VerticalAlignment="Top"
                       Margin="0,3,0,0" Grid.ColumnSpan="2">Reply Post</TextBlock>
            <Button Grid.Column="1" Width="33" BorderThickness="1"
                    BorderBrush="#585D6A" Height="32"
                    VerticalAlignment="Top" HorizontalAlignment="Right"
                    IsEnabled="{Binding SendingComment, Converter={StaticResource BoolNegationConverter}}"
                    Tapped="Close" Padding="0">
                <FontIcon FontWeight="SemiBold" VerticalAlignment="Center"
                          HorizontalAlignment="Center" Foreground="#2fbe7c"
                          FontFamily="ms-appx:///Assets/fonts/segmdl2.ttf#Segoe MDL2 Assets"
                          FontSize="12" Glyph="&#xE8BB;"/>
            </Button>
        </Grid>
        <controls:CommentDialogControl Grid.Row="1">
            <controls:CommentDialogControl.Header>
                <StackPanel Padding="0,5,0,10" BorderBrush="#545A69" Background="#464B57" MinHeight="40" BorderThickness="0,0,0,2">
                    <StackPanel Padding="10,10,10,0">


                        <Grid VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- Avatar -->
                            <toolkit:DropShadowPanel Grid.Column="0" BlurRadius="10" OffsetX="0" ShadowOpacity="0.2" Color="#01b96b" Margin="0,0,10,0" HorizontalAlignment="Center" VerticalAlignment="Center" OffsetY="1">
                                <Grid>
                                    <Grid Background="{StaticResource SystemControlAcrylicElementBrush}" BorderBrush="#01b96b" BorderThickness="2" Width="28" Height="28" CornerRadius="14">
                                        <FontIcon FontFamily="{StaticResource FluentUIGlyphs}" FontSize="14" Foreground="#01b96b" Glyph="&#xE77B;"/>
                                    </Grid>
                                    <Ellipse Width="28" Height="28">
                                        <Ellipse.Fill>
                                            <ImageBrush ImageSource="{Binding Comment.AuthorAvatar}" Stretch="UniformToFill"/>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                </Grid>
                            </toolkit:DropShadowPanel>

                            <!-- AUTHOR + DATE (STRETCHABLE) -->
                            <TextBlock Grid.Column="1" Foreground="#B8BCC5" Margin="0,-4,0,0" TextWrapping="NoWrap">
                            <Run FontSize="12" FontWeight="Bold" Text="{Binding Comment.Author}" />
                            <Run Text=" • " />
                            <Run FontSize="12" FontWeight="SemiBold" Text="{Binding Comment.DateTime, Converter={StaticResource TimestampToElapsedTimeConverter}}" />
                            </TextBlock>
                        </Grid>

                        <TextBlock 
                        x:Name="caption" 
                        TextWrapping="Wrap"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Margin="38,-5,10,0" 
                        Foreground="White"
                        FontSize="12"
                        Text="{Binding Comment.Body}"
                        TextAlignment="Justify" />
                    </StackPanel>
                </StackPanel>

            </controls:CommentDialogControl.Header>
        </controls:CommentDialogControl>
    </Grid>
</ContentDialog>

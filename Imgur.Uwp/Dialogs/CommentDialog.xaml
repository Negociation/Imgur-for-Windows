<ContentDialog
    x:Class="Imgur.Uwp.Dialogs.CommentDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Imgur.Uwp.Dialogs"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    RequestedTheme="Dark"
    Background="#34343A"
    Opacity="1"
    xmlns:Windows10version1809="http://schemas.microsoft.com/winfx/2006/xaml/presentation?IsApiContractPresent(Windows.Foundation.UniversalApiContract, 7)"
    xmlns:Windows10FallCreatorsUpdate="http://schemas.microsoft.com/winfx/2006/xaml/presentation?IsApiContractPresent(Windows.Foundation.UniversalApiContract, 5)"
    xmlns:controls="using:Imgur.Uwp.Controls"
    Windows10version1809:CornerRadius="5"
    FullSizeDesired="False"
    MinWidth="400"
    VerticalAlignment="Center">
    <ContentDialog.Resources>
        <Thickness x:Key="ContentDialogPadding">0,10,0,10</Thickness>
    </ContentDialog.Resources>
    <Grid>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="40"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>
        <!-- Header -->
        <Grid Grid.Row="0" Padding="10,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Foreground="#2fbe7c"
                       FontSize="20" VerticalAlignment="Top"
                       Margin="0,3,0,0" Grid.ColumnSpan="2">Comment Post</TextBlock>
            <Button Grid.Column="1" Width="33" BorderThickness="1"
                    BorderBrush="#585D6A" Height="32"
                    VerticalAlignment="Top" HorizontalAlignment="Right"
                    IsEnabled="{Binding SendingComment, Converter={StaticResource BoolNegationConverter}}"
                    Tapped="Close" Padding="0">
                <FontIcon FontWeight="SemiBold" VerticalAlignment="Center"
                          HorizontalAlignment="Center" Foreground="#2fbe7c"
                          FontFamily="ms-appx:///Assets/fonts/segmdl2.ttf#Segoe MDL2 Assets"
                          FontSize="12" Glyph="&#xE8BB;"/>
            </Button>
        </Grid>
        <controls:CommentDialogControl Grid.Row="1">
            <controls:CommentDialogControl.Header>
                <StackPanel Orientation="Horizontal"
                        BorderThickness="0,0,0,1"
                        BorderBrush="#B8BCC5"
                        Height="80"
                        Opacity="0.9" Padding="10">

                    <!-- Imagem de capa do post -->
                    <Border Width="48" Height="48" CornerRadius="4">
                        <Image Stretch="UniformToFill"
                           Source="{Binding CurrentMedia.CoverPlaceholder}"/>
                    </Border>

                    <StackPanel Margin="10,0">
                        <TextBlock Foreground="White" FontSize="12"
                               FontWeight="Bold"
                               Text="{Binding CurrentMedia.Title, FallbackValue='Imgur Post'}"
                               TextWrapping="Wrap"
                               MaxWidth="200"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="10" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#B8BCC5">by</TextBlock>

                            <HyperlinkButton FontSize="10" Margin="0,0,0,0" Click="HyperlinkButton_Click" IsEnabled="{Binding SendingComment, Converter={StaticResource BoolNegationConverter}}"  Visibility="{Binding UserAccount.UserAccountInfo.IsHidden, Converter={StaticResource BoolNegationConverter}}" Command="{Binding UserAccount.NavigateAccountViewCommand}" FontWeight="SemiBold"  Content="{Binding UserAccount.UserAccountInfo.Username,FallbackValue='...'}" Foreground="{ThemeResource SystemAccentColor}" Height="20" Padding="2,0" Opacity="0.7">
                            </HyperlinkButton>
                        </StackPanel>




                    </StackPanel>
                </StackPanel>
            </controls:CommentDialogControl.Header>
        </controls:CommentDialogControl>
    </Grid>
    
</ContentDialog>
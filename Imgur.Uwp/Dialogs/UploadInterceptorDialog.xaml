<ContentDialog
    x:Class="Imgur.Uwp.Dialogs.UploadInterceptorDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Imgur.Uwp.Dialogs"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
     RequestedTheme="Dark"
    Background="#34343A"
    Opacity="1"
    xmlns:Windows10version1809="http://schemas.microsoft.com/winfx/2006/xaml/presentation?IsApiContractPresent(Windows.Foundation.UniversalApiContract, 7)"
    Windows10version1809:CornerRadius="5"
    FullSizeDesired="False"
    VerticalAlignment="Center"
    >

    <Grid HorizontalAlignment="Stretch" Padding="0" Margin="0,0,0,-1"  VerticalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="40"></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"></ColumnDefinition>
                <ColumnDefinition Width="auto"></ColumnDefinition>
                <ColumnDefinition Width="auto"></ColumnDefinition>

            </Grid.ColumnDefinitions>
            <Image Grid.Column="0" Grid.ColumnSpan="2" Height="24" Source="ms-appx:///Assets/App/sign_transparent.png" VerticalAlignment="Center" />

            <Button Grid.Column="1" Width="33" BorderThickness="1"  BorderBrush="#585D6A" Height="32" VerticalAlignment="Top" HorizontalAlignment="Right" Tapped="Close" Padding="0">
                <FontIcon  FontWeight="SemiBold"  VerticalAlignment="Center" HorizontalAlignment="Center"  Foreground="#2fbe7c" FontFamily="ms-appx:///Assets/fonts/segmdl2.ttf#Segoe MDL2 Assets"  FontSize="12" Glyph="&#xE8BB;" />
            </Button>
        </Grid>
        <TextBlock HorizontalAlignment="Left" Grid.Row="1" Margin="0,20,0,0" TextWrapping="Wrap">In order to upload a file, is required to set a custom API Key to avoid breaking general features.</TextBlock>
        <Grid  CornerRadius="5" Background="#272A33" Padding="0" VerticalAlignment="Top" Margin="0,10" Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>
            <TextBox BorderBrush="Transparent" Background="Transparent" BorderThickness="0" Height="35" TextAlignment="Center" Padding="8" Grid.Column="0" IsReadOnly="True" Foreground="White" Text="{Binding AppRedirectCallback}"/>
            <Grid Grid.Column="1" CornerRadius="0,5,5,0" Background="#2fbe7c" >
                <Button  Grid.Column="1" x:Uid="ClipboardButton" Background="Transparent" BorderThickness="0" Height="35"  Margin="0" Foreground="White"  FontWeight="SemiBold" Command="{Binding Path=Copy}" />
            </Grid>
        </Grid>
        <TextBlock x:Name="ApiKeyInfoText"
           Grid.Row="3"
           HorizontalAlignment="Left"
           FontSize="12"
           Foreground="#2fbe7c"
           TextWrapping="Wrap">
            <Hyperlink NavigateUri="https://imgur.com/account/settings/apps">
                <Run Text="https://imgur.com/account/settings/apps"/>
            </Hyperlink>
        </TextBlock>
        <Button HorizontalAlignment="Center" Style="{StaticResource DefaultButtonStyle}" Command="{Binding OpenSettingsCommand}" Grid.Row="4">
            <TextBlock x:Uid="UploadInterceptorSettings" />
        </Button>
    </Grid>
</ContentDialog>



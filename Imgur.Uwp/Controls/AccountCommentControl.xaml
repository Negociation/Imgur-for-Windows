<UserControl
    x:Class="Imgur.Uwp.Controls.AccountCommentControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Imgur.Uwp.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:toolkit="using:Microsoft.Toolkit.Uwp.UI.Controls"
    mc:Ignorable="d"
    d:DesignHeight="300"
    d:DesignWidth="400">


    <Grid x:Name="Root"
      Background="#1E2124"
         
      Padding="10">

        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="NarrowState"/>

                <VisualState x:Name="WideState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="800"/>
                    </VisualState.StateTriggers>

                    <VisualState.Setters>
                        <Setter Target="CommentCard.Background"
                            Value="#474A51"/>
                        <Setter Target="Root.Background"
                            Value="Transparent"/>
                        <Setter Target="Speech.Visibility"
                            Value="Visible"/>

                        <Setter Target="CommentShadow.ShadowOpacity"
                            Value="0.5"/>

                        <Setter Target="PhotoShadow.ShadowOpacity"
                            Value="0.5"/>
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="87"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Imagem -->
            <toolkit:DropShadowPanel x:Name="PhotoShadow"
                                     Visibility="Visible"
                                     BlurRadius="20"
                                     ShadowOpacity="0"
                                     OffsetY="2">
                <Border Width="87"
                    VerticalAlignment="Top"
                Height="87"
                CornerRadius="4">
                    <Image Stretch="UniformToFill"
                   Source="{Binding Comment.Cover}"/>
                </Border>
            </toolkit:DropShadowPanel>
            <!-- Área do balão -->
            <toolkit:DropShadowPanel x:Name="CommentShadow"
                                         Visibility="Visible"
                                     Grid.Column = "1"
                                         BlurRadius="35"
                                         ShadowOpacity="0"
                                     Margin="10,0,0,0"
                                     HorizontalAlignment="Stretch"
                                     HorizontalContentAlignment="Stretch"
                                         OffsetY="1">
                <Grid x:Name="CommentArea"
              >

                    <!-- Pezinho -->
                    <Path Fill="#474A51"
                      x:Name="Speech"
                      Visibility="Collapsed"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Top"
                      Margin="-11,-4.5,0,0"
                      Data="M 0,20 L 14,0 L 28,20 Z"
                      RenderTransformOrigin="0.5,0.5">

                        <Path.RenderTransform>
                            <RotateTransform Angle="-55"/>
                        </Path.RenderTransform>
                    </Path>




                    <!-- Conteúdo -->
                    <Grid x:Name="CommentCard"
                  Background="Transparent"
                       CornerRadius="0,4,4,4"
                  Padding="10">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                           Foreground="White"
                           FontSize="14"
                           Text="{Binding Comment.Body}"
                           TextWrapping="NoWrap"
                               FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,-4,0,0"/>

                        <StackPanel Grid.Row="1"
                            Margin="0,5"
                                Opacity=".65"
                            Orientation="Horizontal">

                            <StackPanel Orientation="Horizontal">
                                <FontIcon FontSize="18"
                                  Foreground="#f1f6ff"
                                  FontFamily="{StaticResource ImgurGlyphs}"
                                  Glyph="&#xe90b;"/>

                                <TextBlock Margin="5,0"
                                   FontSize="12"
                                   Foreground="#f1f6ff"
                                   FontWeight="SemiBold"
                                   Text="{Binding Comment.Points}"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal"
                                Margin="10,0">

                                <FontIcon FontSize="12"
                                  Foreground="#f1f6ff"
                                  FontFamily="{StaticResource FluentUIGlyphs}"
                                  Glyph="&#xE916;"/>

                                <TextBlock Margin="5,0"
                                   FontSize="12"
                                       Foreground="#f1f6ff"
                                   FontWeight="SemiBold"
                                   Text="{Binding Comment.DateTime, Converter={StaticResource TimestampToElapsedTimeConverter}}"/>
                            </StackPanel>

                        </StackPanel>
                    </Grid>
                </Grid>
            </toolkit:DropShadowPanel>
        </Grid>
    </Grid>
</UserControl>

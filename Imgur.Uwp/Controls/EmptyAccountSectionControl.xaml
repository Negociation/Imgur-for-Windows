<UserControl
    x:Class="Imgur.Uwp.Controls.EmptyAccountSectionControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:Windows10FallCreatorsUpdate="http://schemas.microsoft.com/winfx/2006/xaml/presentation?IsApiContractPresent(Windows.Foundation.UniversalApiContract, 5)"
    mc:Ignorable="d"
    d:DesignHeight="200"
    d:DesignWidth="400">

    <Grid Padding="20,30">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Windows10FallCreatorsUpdate:Spacing="8">

            <Image
                Source="ms-appx:///Assets/App/giraffe_faded.png"
                MaxWidth="70"
                Opacity="0.45"
                HorizontalAlignment="Center" />

            <TextBlock
                x:Uid="EmptySectionTitle"
                HorizontalAlignment="Center"
                FontSize="14"
                FontWeight="SemiBold"
                Foreground="White"
                Opacity="0.6"
                TextAlignment="Center" />

            <TextBlock
                x:Uid="EmptySectionSubtitle"
                HorizontalAlignment="Center"
                FontSize="12"
                Foreground="White"
                Opacity="0.4"
                TextAlignment="Center"
                TextWrapping="Wrap"
                MaxWidth="260" />

        </StackPanel>
    </Grid>
</UserControl>

<UserControl
    x:Class="Imgur.Uwp.Controls.CommentControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Imgur.Uwp.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="300"
    xmlns:toolkit="using:Microsoft.Toolkit.Uwp.UI.Controls"
    d:DesignWidth="400">

    <Grid x:Name="Root" Height="Auto"  Margin="0" Background="#1E2124">

        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Uid="PageTriggers">
                <VisualState x:Name="Compact">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="500" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="Comment.Background" Value="#464b57" />
                        <Setter Target="Root.Background" Value="#2F333B" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
        <StackPanel>
            <Grid>

                <Button Padding="0" HorizontalAlignment="Stretch" Style="{x:Null}" Command="{Binding ToggleRepliesCommand}" HorizontalContentAlignment="Stretch" BorderBrush="#31353D" BorderThickness="0,0,0,2"  Background="Transparent">
                    <StackPanel x:Name="Comment"  Background="#3D4140" Padding="10,10,0,0" >
                        <StackPanel Padding="0,0">


                            <Grid VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <!-- Avatar -->
                                <toolkit:DropShadowPanel Grid.Column="0" BlurRadius="10" OffsetX="0" ShadowOpacity="0.2" Color="#01b96b" Margin="0,0,10,0" HorizontalAlignment="Center" VerticalAlignment="Center" OffsetY="1">
                                    <Grid>
                                        <Grid Background="{StaticResource SystemControlAcrylicElementBrush}" BorderBrush="#01b96b" BorderThickness="2" Width="28" Height="28" CornerRadius="14">
                                            <FontIcon FontFamily="{StaticResource FluentUIGlyphs}" FontSize="14" Foreground="#01b96b" Glyph="&#xE77B;"/>
                                        </Grid>
                                        <Ellipse Width="28" Height="28">
                                            <Ellipse.Fill>
                                                <ImageBrush ImageSource="{Binding Comment.AuthorAvatar}" Stretch="UniformToFill"/>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                    </Grid>
                                </toolkit:DropShadowPanel>

                                <!-- AUTHOR + DATE (STRETCHABLE) -->
                                <TextBlock Grid.Column="1" Foreground="#B8BCC5"  HorizontalAlignment="Stretch" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" Margin="0,-4,0,0" >
                                <Run FontSize="12" FontWeight="Bold" Text="{Binding Comment.Author}" />
                                <Run Text=" • " />
                                <Run FontSize="12" FontWeight="SemiBold"  Text="{Binding Comment.DateTime, Converter={StaticResource TimestampToElapsedTimeConverter}}" />
                                <ToolTipService.ToolTip>
                                    <TextBlock>
                                        <Run Text="{Binding Comment.Author}" />
                                        <Run Text=" • " />
                                        <Run Text="{Binding Comment.DateTime, Converter={StaticResource TimestampToElapsedTimeConverter}}" />
                                    </TextBlock>
                                </ToolTipService.ToolTip>
                            </TextBlock>


                                <!-- REPLIES -->
                                <StackPanel   Background="#2F3035" CornerRadius="10" Padding="10,0" Height="20" Grid.Column="2" Orientation="Horizontal"  HorizontalAlignment="Right" Margin="0,-12,10,0">
                                    <FontIcon FontFamily="{StaticResource FluentUIGlyphs}" FontSize="10" Margin="0,2,5,0" FontWeight="ExtraBold" Foreground="#B8BCC5" Visibility="{Binding RepliesVisibility, Converter={StaticResource BoolNegationConverter}}" Glyph="&#xE96E;"/>
                                    <FontIcon FontFamily="{StaticResource FluentUIGlyphs}" FontSize="10" Margin="0,0,5,0" FontWeight="ExtraBold" Foreground="#B8BCC5" Visibility="{Binding RepliesVisibility}" Glyph="&#xE96D;"/>

                                
                                    <TextBlock  Foreground="#B8BCC5" Text="{Binding Comment.ReplyCount}" VerticalAlignment="Center" FontWeight="Bold" FontSize="10"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock 
                            x:Name="caption" 
                            TextWrapping="Wrap"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Margin="38,-5,20,0" 
                            Foreground="White"
                            FontSize="12"
                            Text="{Binding Comment.Body}"
                            TextAlignment="Justify" />

                            <Grid x:Name="selectedActions" Height="40" Margin="38,0,0,0">
                                <StackPanel HorizontalAlignment="Left"  Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Background="Transparent" BorderBrush="Transparent" FocusVisualPrimaryBrush="{StaticResource SystemControlFocusVisualPrimaryBrush}" FocusVisualSecondaryBrush="{StaticResource SystemControlFocusVisualSecondaryBrush}" Width="30" Height="30" Padding="-5" Command="{Binding Vote}" CommandParameter="up">
                                        <FontIcon FontSize="18" Foreground="{Binding Comment.IsUpvoted, Converter={StaticResource BoolToBrushConverter}, ConverterParameter=#1bb76e|#FFFFFF}" FontFamily="{StaticResource ImgurGlyphs}" Glyph="&#xe90b;"/>
                                    </Button>

                                    <TextBlock HorizontalAlignment="Center" Foreground="#B8BCC5"  FontSize="12" TextAlignment="Center" Height="15" VerticalAlignment="Center" FontWeight="SemiBold" Text="{Binding Comment.Points}" Margin="10,0" />

                                    <Button Background="Transparent" BorderBrush="Transparent" FocusVisualPrimaryBrush="{StaticResource SystemControlFocusVisualPrimaryBrush}" FocusVisualSecondaryBrush="{StaticResource SystemControlFocusVisualSecondaryBrush}"  Height="30" Width="30" Padding="-5" Command="{Binding Vote}" CommandParameter="down">
                                        <Button.Content>
                                            <FontIcon FontSize="18" FontWeight="Light" Foreground="{Binding Comment.IsDownvoted, Converter={StaticResource BoolToBrushConverter}, ConverterParameter=#1bb76e|#FFFFFF}" FontFamily="{StaticResource ImgurGlyphs}" Glyph="&#xe900;"/>
                                        </Button.Content>
                                    </Button>
                                </StackPanel>

                                <StackPanel HorizontalAlignment="Right" Margin="0,0,10,0"  Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button x:Uid="Reply" Background="Transparent" BorderBrush="Transparent" Foreground="#B8BCC5" FocusVisualPrimaryBrush="{StaticResource SystemControlFocusVisualPrimaryBrush}" FocusVisualSecondaryBrush="{StaticResource SystemControlFocusVisualSecondaryBrush}" FontSize="12" Height="30" Padding="10,-5" Command="{Binding StartCommentCommand}">
                                    
                                    </Button>
                                    <Button Background="Transparent" Foreground="#B8BCC5" BorderBrush="Transparent" FocusVisualPrimaryBrush="{StaticResource SystemControlFocusVisualPrimaryBrush}" FocusVisualSecondaryBrush="{StaticResource SystemControlFocusVisualSecondaryBrush}" Width="30" Height="30" Padding="-5">
                                        <SymbolIcon Symbol="More"></SymbolIcon>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                    </StackPanel>

                </Button>
                <Rectangle Width="2" HorizontalAlignment="Left" VerticalAlignment="Stretch" Fill="#FF6C6C6C" Visibility="{Binding Comment.IsRootComment, Converter={StaticResource BoolNegationConverter} }"/>
            </Grid>
            <ListView
                    ScrollViewer.VerticalScrollMode="Disabled" 
                    x:Name="replies"
                    x:DeferLoadStrategy="Lazy" ItemsSource="{Binding Replies}"
                    Margin="0,0,0,0" SelectionMode="None" 
                    Visibility="{Binding ShowReplies, Converter={StaticResource BoolVisibilityConverter}}"
                    HorizontalContentAlignment="Stretch">
                <ListView.ItemContainerTransitions>
                    <TransitionCollection>
                        <RepositionThemeTransition/>
                    </TransitionCollection>
                </ListView.ItemContainerTransitions>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="0,0,0,0" Margin="0,0,-12,0"  >
                            <local:CommentControl/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>
    </Grid>
</UserControl>


<Page
    x:Name="AccountViewPage"
    x:Class="Imgur.Uwp.Views.Accounts.AccountView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Imgur.Uwp.Views.Accounts"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:toolkit="using:Microsoft.Toolkit.Uwp.UI.Controls"
    xmlns:controls="using:Imgur.Uwp.Controls"
    xmlns:mediavm="using:Imgur.ViewModels.Media"
    xmlns:commentvm="using:Imgur.ViewModels.Account"
    SizeChanged="AccountViewPage_SizeChanged"
    mc:Ignorable="d">

    <Page.Resources>

        <Style x:Key="CommentMobileStyle" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style x:Key="CommentDesktopStyle" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

    </Page.Resources>
    
    <Grid>
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="LeaveButton">
                <VisualState x:Name="LeaveButtonMobileInlineState">
                    <VisualState.Setters>
                        <Setter Target="LeaveFloatButton.Margin" Value="10,18,0,0"/>
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>

            <VisualStateGroup  x:Uid="RootViewTriggers">
                <VisualState>
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="300" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="AccountViewPage.Margin" Value="0,-10,0,0"/>
                        <Setter Target="ExpandedHeader.Height" Value="200"/>
                    </VisualState.Setters>
                </VisualState>
                <VisualState>
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="500" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="AccountViewPage.Margin" Value="-5,-50,0,0"/>
                        <Setter Target="AccountViewPage.Padding" Value="0"/>
                        <Setter Target="LeaveFloatButton.Margin" Value="17,17,0,0"/>
                        <Setter Target="LeaveFloatButton.Background" Value="#AD19191C"/>

                    </VisualState.Setters>
                </VisualState>
                <VisualState>
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="800" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="AccountViewPage.Margin" Value="-5,-80,0,0"/>
                        <Setter Target="AccountViewPage.Padding" Value="0"/>
                        <Setter Target="ExpandedHeader.Height" Value="350"/>
                        <Setter Target="LeaveFloatButton.Margin" Value="17,30,0,0"/>
                        <Setter Target="LeaveFloatButton.MinWidth" Value="34"/>
                        <Setter Target="LeaveFloatButton.MinHeight" Value="34"/>
                    </VisualState.Setters>
                </VisualState>
                <VisualState>
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1100" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="AccountViewPage.Margin" Value="-5,-80,0,0"/>
                        <Setter Target="AccountViewPage.Padding" Value="0"/>
                        <Setter Target="ExpandedHeader.Height" Value="400"/>
                        <Setter Target="LeaveFloatButton.Margin" Value="17,30,0,0"/>
                        <Setter Target="LeaveFloatButton.MinWidth" Value="34"/>
                        <Setter Target="LeaveFloatButton.MinHeight" Value="34"/>

                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>

            <VisualStateGroup  x:Uid="AccountViewTriggers">
                <VisualState>
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="300" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="UserInfoPanel.Width" Value="380"/>
                    </VisualState.Setters>
                </VisualState>
                <VisualState>
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="800" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="CommentsRepeaterControl.Margin" Value="20,30,40,20"/>
                        <Setter Target="UserInfoPanel.Margin" Value="40,40,0,0"/>
                        <Setter Target="UserInfoPanel.Width" Value="400"/>
                    </VisualState.Setters>
                </VisualState>
                <VisualState>
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1100" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="CommentsRepeaterControl.Margin" Value="40,30,40,40"/>
                        <Setter Target="UserInfoPanel.Margin" Value="40,40,0,0"/>
                        <Setter Target="UserInfoPanel.Width" Value="600"/>
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
            <VisualStateGroup x:Uid="MediaViewTriggers">
                <VisualState x:Name="MediaGrid_Small">
                    <VisualState.Setters>
                        <Setter Target="PostsContentRepeaterControl.DesiredWidth" Value="250" />
                        <Setter Target="PostsContentRepeaterControl.ItemHeight" Value="200" />
                        <Setter Target="FavoritesContentRepeaterControl.DesiredWidth" Value="250" />
                        <Setter Target="FavoritesContentRepeaterControl.ItemHeight" Value="200" />
                        
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="MediaGrid_Medium">
                    <VisualState.Setters>
                        <Setter Target="PostsContentRepeaterControl.DesiredWidth" Value="300" />
                        <Setter Target="PostsContentRepeaterControl.ItemHeight" Value="220" />
                        <Setter Target="FavoritesContentRepeaterControl.DesiredWidth" Value="300" />
                        <Setter Target="FavoritesContentRepeaterControl.ItemHeight" Value="220" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="MediaGrid_Larger">
                    <VisualState.Setters>
                        <Setter Target="PostsContentRepeaterControl.DesiredWidth" Value="400" />
                        <Setter Target="PostsContentRepeaterControl.ItemHeight" Value="280" />
                        <Setter Target="FavoritesContentRepeaterControl.DesiredWidth" Value="400" />
                        <Setter Target="FavoritesContentRepeaterControl.ItemHeight" Value="280" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
        <ScrollViewer x:Name="MainScrollViewer" 
                      Padding="0,0,0,0"
                      ViewChanged="MainScrollViewer_ViewChanged"
                      VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                </Grid.RowDefinitions>
                <Grid x:Name="ExpandedHeader" 
                      Height="250"
                      VerticalAlignment="Top">
                    <Grid.Background>
                        <ImageBrush Opacity="0.8" ImageSource="{Binding UserAccountInfo.Cover}"
                            Stretch="UniformToFill"
                            AlignmentX="Center"
                            AlignmentY="Center"/>
                    </Grid.Background>
                    <Grid Background="Black" Opacity="0.3"></Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Viewbox x:Name="UserInfoPanel" Width="320"  Margin="30,0,0,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Top" >
                                <toolkit:DropShadowPanel
                                    BlurRadius="50" 
                                    OffsetX="0" 
                                    ShadowOpacity="0.5" 
                                    Margin="0,0,0,0" HorizontalAlignment="Center" VerticalAlignment="Top"
                                    OffsetY="1" >
                                    <Grid Background="{StaticResource SystemControlAcrylicElementBrush}" Width="160" Height="160" x:Name="UserPictureGrid" CornerRadius="80" Padding="0">


                                        <ProgressRing x:Name="LoadingAvatarRing" VerticalAlignment="Center"  Width="60" Height="50" Margin="0,0,0,0" IsActive="True"  />
                                        <FontIcon  Grid.RowSpan="2" FontFamily="{StaticResource FluentUIGlyphs}" FontSize="30" Foreground="#01b96b" Margin="0,0,0,0" Glyph="&#xe8d4;"/>
                                        <Ellipse Width="160" Height="160"  x:Name="UserPicture" >
                                            <Ellipse.Fill>
                                                <ImageBrush ImageSource="{Binding UserAccountInfo.Avatar}" Stretch="UniformToFill"/>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                    </Grid>

                                </toolkit:DropShadowPanel>
                                <Grid Grid.Row="0" Margin="30,0,10,0" Padding="10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"  />
                                        <RowDefinition Height="Auto"  />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"  TextWrapping="NoWrap" FontSize="30" FontWeight="Bold" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{Binding UserAccountInfo.Username,Mode=OneWay}"   Text="{Binding UserAccountInfo.Username,FallbackValue='Username',Mode=OneWay }"/>
                                    <TextBlock x:Name="UserDesc" Grid.Row="1"  Margin="0,0,0,0" FontSize="25">
                                <Run ToolTipService.ToolTip="{Binding UserAccountInfo.ReputationName,Mode=OneWay}" FontWeight="SemiBold"   Text="{Binding UserAccountInfo.ReputationName,FallbackValue='Username',Mode=OneWay }"/>
                                <Run Text=" • "></Run>      
                                <Run FontWeight="SemiBold" Text="{Binding UserAccountInfo.Reputation}"></Run>
                                <Run x:Uid="Points" FontWeight="SemiBold"  Text=" Points"></Run>
                                    </TextBlock>
                                    <toolkit:DropShadowPanel Grid.Row="2" x:Name="UserFollowButton" Visibility="{Binding IsUserOwnPage, Converter={StaticResource BoolNegationConverter}}" BlurRadius="20" Margin="0,10" OffsetX="0" OffsetY="2" ShadowOpacity="0.5" HorizontalContentAlignment="Stretch" HorizontalAlignment="Left" VerticalAlignment="Top" Padding="0,0" VerticalContentAlignment="Stretch">
                                        <Button x:Name="UserFollow" Style="{StaticResource FollowButtonStyle}" Command="{Binding FollowAuthor}"  Opacity="1">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Uid="Follow" Visibility="{Binding IsFollowing, Converter={StaticResource BoolNegationConverter}}"></TextBlock>
                                                <TextBlock x:Uid="Unfollow" Visibility="{Binding IsFollowing, Converter={StaticResource BoolVisibilityConverter}}"></TextBlock>
                                            </StackPanel>
                                        </Button>
                                    </toolkit:DropShadowPanel>
                                </Grid>
                                
                            </StackPanel>
                        </Viewbox>


                    </StackPanel>
                </Grid>




                <Grid Grid.Row="1">

                    <Grid Height="60" HorizontalAlignment="Stretch" VerticalAlignment="Top" >
                        <toolkit:DropShadowPanel  VerticalAlignment="Top" Margin="0,39,0,0"  BlurRadius="10"  OffsetX="0" OffsetY="0" ShadowOpacity="0.5"  HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Padding="0,0" VerticalContentAlignment="Stretch">
                            <Button HorizontalAlignment="Stretch" Padding="0" Height="10" VerticalAlignment="Stretch" HorizontalContentAlignment="Stretch" Background="Transparent" Style="{x:Null}" BorderThickness="0" />
                        </toolkit:DropShadowPanel>
                        <Grid BorderThickness="0,1,0,1" MaxHeight="44" BorderBrush="#1D1D1F" VerticalAlignment="Top">
                            <Rectangle Height="47" HorizontalAlignment="Stretch"  VerticalAlignment="Stretch" Fill="{StaticResource SystemControlAcrylicElementBrush}" />
                        </Grid>
 
                    </Grid>


                        <Pivot x:Name="AccountPivot" Margin="0,-3,0,0" SelectionChanged="AccountPivot_SelectionChanged">
                        <Pivot.Resources>
                            <Style TargetType="PivotHeaderItem">
                                <Setter Property="Margin" Value="12,0"/>
                                <Setter Property="Padding" Value="0"/>
                            </Style>
                            <Thickness x:Key="PivotHeaderItemMargin">12,0,12,0</Thickness>
                        </Pivot.Resources>

                        <!-- Submissions -->
                        <PivotItem x:Uid="PostsHeader" Header="Posts">
                            <Grid MinHeight="200" Visibility="{Binding LoadedSuccessfully, Converter={StaticResource BoolVisibilityConverter}, FallbackValue='False'}">
                                <controls:EmptyAccountSectionControl Visibility="{Binding IsSubmissionsEmpty, Converter={StaticResource BoolVisibilityConverter}}" />

                                <toolkit:AdaptiveGridView
                                    x:Name="PostsContentRepeaterControl"
                                    Margin="0,10,0,0"
                                    IncrementalLoadingTrigger="Edge"
                                    IncrementalLoadingThreshold="0.1"
                                    ItemsSource="{Binding SubmissionsCollection, Mode=OneWay}"
                                    IsItemClickEnabled="True"
                                    DataFetchSize="1"
                                    SelectionMode="None"
                                    DesiredWidth="250"
                                    ItemHeight="200">
                                    <toolkit:AdaptiveGridView.ItemContainerStyle>
                                        <Style TargetType="GridViewItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Margin" Value="0"/>
                                            <Setter Property="Padding" Value="0"/>
                                        </Style>
                                    </toolkit:AdaptiveGridView.ItemContainerStyle>

                                    <toolkit:AdaptiveGridView.ItemTemplate>
                                        <DataTemplate x:DataType="mediavm:MediaViewModel">
                                            <controls:MediaTileControl ViewModel="{Binding}" />
                                        </DataTemplate>
                                    </toolkit:AdaptiveGridView.ItemTemplate>

                                    <toolkit:AdaptiveGridView.Footer>
                                        <Grid HorizontalAlignment="Stretch" Margin="0,15,0,15">
                                            <Button HorizontalAlignment="Center"
                                                    Visibility="{Binding ShowLoadMoreSubmissionsButton, Converter={StaticResource BoolVisibilityConverter}}"
                                                    VerticalAlignment="Top"
                                                    Command="{Binding LoadMoreSubmissionsCommand}"
                                                    Style="{StaticResource AppRoundedButtonStyle}">
                                                <TextBlock x:Uid="LoadMore"></TextBlock>
                                            </Button>
                                            <ProgressBar HorizontalAlignment="Stretch" IsIndeterminate="True" Margin="50,15"
                                                         Visibility="{Binding IsLoadingNewPage, Converter={StaticResource BoolVisibilityConverter}}" />
                                        </Grid>
                                    </toolkit:AdaptiveGridView.Footer>
                                </toolkit:AdaptiveGridView>
                            </Grid>
                        </PivotItem>

                        <!-- Favourites -->
                        <PivotItem x:Uid="FavouritesHeader" Header="Favourites">
                            <Grid MinHeight="200" Visibility="{Binding LoadedSuccessfully, Converter={StaticResource BoolVisibilityConverter}, FallbackValue='False'}">
                                <controls:EmptyAccountSectionControl Visibility="{Binding IsFavoritesEmpty, Converter={StaticResource BoolVisibilityConverter}}" />

                                <toolkit:AdaptiveGridView
                                    x:Name="FavoritesContentRepeaterControl"
                                    Margin="0,10,0,0"
                                    IncrementalLoadingTrigger="Edge"
                                    IncrementalLoadingThreshold="0.1"
                                    ItemsSource="{Binding FavoritesCollection, Mode=OneWay}"
                                    IsItemClickEnabled="True"
                                    DataFetchSize="1"
                                    SelectionMode="None"
                                    DesiredWidth="250"
                                    ItemHeight="200">
                                    <toolkit:AdaptiveGridView.ItemContainerStyle>
                                        <Style TargetType="GridViewItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Margin" Value="0"/>
                                            <Setter Property="Padding" Value="0"/>
                                        </Style>
                                    </toolkit:AdaptiveGridView.ItemContainerStyle>

                                    <toolkit:AdaptiveGridView.ItemTemplate>
                                        <DataTemplate x:DataType="mediavm:MediaViewModel">
                                            <controls:MediaTileControl ViewModel="{Binding}" />
                                        </DataTemplate>
                                    </toolkit:AdaptiveGridView.ItemTemplate>

                                    <toolkit:AdaptiveGridView.Footer>
                                        <Grid HorizontalAlignment="Stretch" Margin="0,15,0,15">
                                           
                                            <Button HorizontalAlignment="Center"
                                                    Visibility="{Binding ShowLoadMoreFavoritesButton, Converter={StaticResource BoolVisibilityConverter}}"
                                                    VerticalAlignment="Top"
                                                    Command="{Binding LoadMoreFavoritesCommand}"
                                                    Style="{StaticResource AppRoundedButtonStyle}">
                                                <TextBlock x:Uid="LoadMore"></TextBlock>
                                            </Button>
                                            <ProgressBar HorizontalAlignment="Stretch" IsIndeterminate="True" Margin="50,15"
                                                         Visibility="{Binding IsLoadingNewPage, Converter={StaticResource BoolVisibilityConverter}}" />
                                        </Grid>
                                    </toolkit:AdaptiveGridView.Footer>
                                </toolkit:AdaptiveGridView>
                            </Grid>
                        </PivotItem>

                        <!-- Comments -->
                        <PivotItem x:Uid="CommentsHeader" Header="Comments" Visibility="{Binding LoadedSuccessfully, Converter={StaticResource BoolVisibilityConverter}, FallbackValue='False'}">
                            <Grid MinHeight="200">
                                <controls:EmptyAccountSectionControl Visibility="{Binding IsCommentsEmpty, Converter={StaticResource BoolVisibilityConverter}}" />
                                <ListView
                                    x:Name="CommentsRepeaterControl"
                                    Margin="-12,10,-12,40"
                                    MaxWidth="900"
                                    IncrementalLoadingTrigger="Edge"
                                    DataFetchSize="1"
                                    ItemsSource="{Binding CommentsCollection, Mode=OneWay}"
                                    SelectionMode="None">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Margin" Value="0,0,0,8"/>
                                            <Setter Property="Padding" Value="0"/>
                                        </Style>
                                    </ListView.ItemContainerStyle>

                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="mediavm:CommentViewModel">
                                          <!--  <controls:CommentTileControl ViewModel="{Binding}" /> -->
                                            <Grid HorizontalAlignment="Stretch">
                                                <Button Padding="0" Style="{x:Null}" BorderThickness="0" Background="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                                                    <controls:AccountCommentControl/>
                                                </Button>
                                                
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>

                                    <ListView.Footer>
                                        <Grid HorizontalAlignment="Stretch" Margin="0,15,0,15">
                                            
                                            <Button HorizontalAlignment="Center"
                                                    Visibility="{Binding ShowLoadMoreCommentsButton, Converter={StaticResource BoolVisibilityConverter}}"
                                                    VerticalAlignment="Top"
                                                    Command="{Binding LoadMoreCommentsCommand}"
                                                    Style="{StaticResource AppRoundedButtonStyle}">
                                                <TextBlock x:Uid="LoadMore"></TextBlock>
                                            </Button>
                                            <ProgressBar HorizontalAlignment="Stretch" IsIndeterminate="True" Margin="50,15"
                                                         Visibility="{Binding IsLoadingNewPage, Converter={StaticResource BoolVisibilityConverter}}" />
                                        </Grid>
                                    </ListView.Footer>
                                </ListView>
                            </Grid>
                        </PivotItem>
                    </Pivot>

                    <!-- Error Page sobre o Pivot inteiro: visível quando LoadedSuccessfully == false E Loading == false -->
                    <Grid x:Name="AccountErrorGrid"
                          Background="Transparent"
                          Opacity="0.7"
                          Visibility="{Binding ShowErrorPage, Converter={StaticResource BoolVisibilityConverter}, FallbackValue='False'}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="0.2*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,-30,0,0">
                            <Image MaxWidth="250" Source="ms-appx:///Assets/App/raccon.png"/>
                            <TextBlock Margin="0,10,0,0" TextWrapping="Wrap" FontWeight="ExtraBold" TextAlignment="Center" FontSize="25">
                                Imgur, we have a problem.
                            </TextBlock>
                            <TextBlock Margin="0,10,0,0" TextWrapping="Wrap" TextAlignment="Center" FontSize="18">Sorry, We're encountering some technical difficulties.</TextBlock>
                            <Button Margin="0,10,0,0" HorizontalAlignment="Center" MinWidth="200" Command="{Binding RetryCommand}">Reload</Button>
                        </StackPanel>
                    </Grid>

                    <!-- Loading Ring sobre o Pivot enquanto carrega -->
                    <ProgressRing Width="80" Height="80" FontWeight="SemiLight"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  IsActive="{Binding Loading}"
                                  Visibility="{Binding Loading, Converter={StaticResource BoolVisibilityConverter}, FallbackValue='False'}"/>
                </Grid>
            </Grid>
        </ScrollViewer>

        <!-- Go Back Button -->
        <Button Grid.Column="0" x:Name="LeaveFloatButton" Command="{Binding LeaveCurrentPage}" VerticalAlignment="Top" Style="{StaticResource CircleButtonStyle}" Margin="11,15,0,0" Width="30" Height="30" Background="#19191C" Opacity="1" >
            <FontIcon Visibility="Visible"  Grid.Column="0" FontSize="14" FontWeight="ExtraBold" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="{StaticResource FluentUIGlyphs}" Foreground="White" Glyph="&#xE72B;"/>
        </Button>

        <!-- Bottom Navigation Bar — Posts -->
        <StackPanel x:Name="BottomBarPosts" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10" VerticalAlignment="Bottom" Visibility="Visible">
            <toolkit:DropShadowPanel OffsetY="5" OffsetX="0" BlurRadius="20" ShadowOpacity="0.4">
                <Button Style="{StaticResource CircleButtonStyle}" Background="{StaticResource SystemControlBackgroundAccentBrush}" Command="{Binding ReloadSubmissionsCommand}" Width="48" Height="48" ToolTipService.ToolTip="Refresh Posts">
                    <FontIcon FontSize="20" FontWeight="SemiLight" VerticalAlignment="Center" FontFamily="{StaticResource SegoeMDLGlyphs}" Foreground="WhiteSmoke" Glyph="&#xE72C;"/>
                </Button>
            </toolkit:DropShadowPanel>
            <toolkit:DropShadowPanel OffsetY="5" OffsetX="0" BlurRadius="20" ShadowOpacity="0.5" Margin="10,0,0,0">
                <Button Style="{StaticResource CircleButtonStyle}" Background="{StaticResource SystemControlBackgroundAccentBrush}" Click="NavigateToTop_Click" Width="48" Height="48" IsEnabled="{Binding CanScrollToTop, FallbackValue='False'}" ToolTipService.ToolTip="Move to the top">
                    <FontIcon FontSize="20" Margin="1,0,0,0" FontWeight="SemiLight" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="{StaticResource SegoeMDLGlyphs}" Foreground="WhiteSmoke" Glyph="&#xE898;"/>
                </Button>
            </toolkit:DropShadowPanel>
        </StackPanel>

        <!-- Bottom Navigation Bar — Favourites -->
        <StackPanel x:Name="BottomBarFavorites" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10" VerticalAlignment="Bottom" Visibility="Collapsed">
            <toolkit:DropShadowPanel OffsetY="5" OffsetX="0" BlurRadius="20" ShadowOpacity="0.4">
                <Button Style="{StaticResource CircleButtonStyle}" Background="{StaticResource SystemControlBackgroundAccentBrush}" Command="{Binding ReloadFavoritesCommand}" Width="48" Height="48" ToolTipService.ToolTip="Refresh Favourites">
                    <FontIcon FontSize="20" FontWeight="SemiLight" VerticalAlignment="Center" FontFamily="{StaticResource SegoeMDLGlyphs}" Foreground="WhiteSmoke" Glyph="&#xE72C;"/>
                </Button>
            </toolkit:DropShadowPanel>
            <toolkit:DropShadowPanel OffsetY="5" OffsetX="0" BlurRadius="20" ShadowOpacity="0.5" Margin="10,0,0,0">
                <Button Style="{StaticResource CircleButtonStyle}" Background="{StaticResource SystemControlBackgroundAccentBrush}" Click="NavigateToTop_Click" Width="48" Height="48" IsEnabled="{Binding CanScrollToTop, FallbackValue='False'}" ToolTipService.ToolTip="Move to the top">
                    <FontIcon FontSize="20" Margin="1,0,0,0" FontWeight="SemiLight" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="{StaticResource SegoeMDLGlyphs}" Foreground="WhiteSmoke" Glyph="&#xE898;"/>
                </Button>
            </toolkit:DropShadowPanel>
        </StackPanel>

        <!-- Bottom Navigation Bar — Comments -->
        <StackPanel x:Name="BottomBarComments" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10" VerticalAlignment="Bottom" Visibility="Collapsed">
            <toolkit:DropShadowPanel OffsetY="5" OffsetX="0" BlurRadius="20" ShadowOpacity="0.4">
                <Button Style="{StaticResource CircleButtonStyle}" Background="{StaticResource SystemControlBackgroundAccentBrush}" Command="{Binding ReloadCommentsCommand}" Width="48" Height="48" ToolTipService.ToolTip="Refresh Comments">
                    <FontIcon FontSize="20" FontWeight="SemiLight" VerticalAlignment="Center" FontFamily="{StaticResource SegoeMDLGlyphs}" Foreground="WhiteSmoke" Glyph="&#xE72C;"/>
                </Button>
            </toolkit:DropShadowPanel>
            <toolkit:DropShadowPanel OffsetY="5" OffsetX="0" BlurRadius="20" ShadowOpacity="0.5" Margin="10,0,0,0">
                <Button Style="{StaticResource CircleButtonStyle}" Background="{StaticResource SystemControlBackgroundAccentBrush}" Click="NavigateToTop_Click" Width="48" Height="48" IsEnabled="{Binding CanScrollToTop, FallbackValue='False'}" ToolTipService.ToolTip="Move to the top">
                    <FontIcon FontSize="20" Margin="1,0,0,0" FontWeight="SemiLight" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="{StaticResource SegoeMDLGlyphs}" Foreground="WhiteSmoke" Glyph="&#xE898;"/>
                </Button>
            </toolkit:DropShadowPanel>
        </StackPanel>

    </Grid>
</Page>
